---
import Layout from './Layout.astro';

const { title, description, pubDate, author, image, tags = [] } = Astro.props;

// Ensure Date format
const displayDate = new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${title} | Myst-Blog`} description={description} image={image}>
    <main class="max-w-3xl mx-auto px-4 w-full pt-16">
        <article class="py-12">
            <header class="text-center mb-16">
                {tags.length > 0 && (
                    <div class="flex justify-center gap-3 mb-8 flex-wrap">
                        {tags.map((tag: string) => (
                            <span class="text-xs font-bold tracking-widest uppercase text-[#86868b]">
                                {tag}
                            </span>
                        ))}
                    </div>
                )}
                <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-[#1d1d1f] dark:text-[#f5f5f7] mb-8 leading-tight">{title}</h1>
                <div class="flex items-center justify-center text-[#86868b] text-sm font-semibold tracking-wide uppercase space-x-3">
                    <span class="author">{author}</span>
                    <span>&bull;</span>
                    <time class="date" dateTime={new Date(pubDate).toISOString()}>{displayDate}</time>
                </div>
            </header>

            {image && (
                <div class="w-full rounded-3xl overflow-hidden mb-16 aspect-video bg-[#f5f5f7] dark:bg-[#1d1d1f]">
                    <img src={image} alt={`Cover for ${title}`} class="object-cover w-full h-full" />
                </div>
            )}

            <div class="prose prose-xl prose-slate dark:prose-invert max-w-none text-[#1d1d1f] dark:text-[#f5f5f7] prose-headings:font-bold prose-headings:tracking-tight prose-a:text-[#0066cc] dark:prose-a:text-[#2997ff] prose-a:no-underline hover:prose-a:underline prose-p:leading-relaxed">
                <slot />
            </div>
        </article>
    </main>
</Layout>
