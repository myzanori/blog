---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
// Sort by date descending
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Myst-Blog | Home" description="A premium tech blog exploring software, UI/UX, and the future of the web.">
    <main class="w-full min-h-screen">
        <section class="py-24 md:py-32 flex flex-col items-center text-center px-4 border-b border-black/5 dark:border-white/10">
            <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-[#1d1d1f] dark:text-[#f5f5f7] mb-6 max-w-4xl">
                Hi, I'm Mohammed Yamin Salman.
            </h1>
            <p class="text-lg font-semibold tracking-widest uppercase text-[#86868b] mb-10">
                Mythanor | he/him
            </p>
            <p class="text-xl md:text-2xl font-medium tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] max-w-3xl mb-6">
                I'm a 22-year-old researcher and developer based in Hyderabad. Currently pursuing my Master of Pharmacy in Pharmaceutical Chemistry after graduating from the Deccan School of Pharmacy.
            </p>
            <p class="text-xl md:text-2xl font-medium tracking-tight text-[#86868b] max-w-3xl">
                Coding is my passion. I enjoy building tools, websites, and exploring the intersection of technology and research.
            </p>
        </section>

        <section class="max-w-4xl mx-auto px-4 py-16">
            <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868b] mb-12">Latest Writing</h2>
            
            <div class="flex flex-col">
                {allPosts.map((post) => (
                    <article class="group relative flex flex-col md:flex-row md:items-baseline justify-between py-8 border-b border-black/5 dark:border-white/10 first:pt-0 last:border-0">
                        <a href={`/posts/${post.id}`} class="absolute inset-0 z-10" aria-label={`Read ${post.data.title}`}></a>
                        
                        <div class="flex-1 md:pr-8">
                            <h3 class="text-2xl font-bold tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] group-hover:text-[#0066cc] dark:group-hover:text-[#2997ff] transition-colors mb-3">
                                {post.data.title}
                            </h3>
                            <p class="text-lg text-[#86868b] line-clamp-2 font-medium">
                                {post.data.description}
                            </p>
                        </div>
                        
                        <time dateTime={post.data.pubDate.toISOString()} class="mt-4 md:mt-0 text-sm font-semibold tracking-wide text-[#86868b] whitespace-nowrap">
                            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                        </time>
                    </article>
                ))}
            </div>
        </section>
    </main>
</Layout>