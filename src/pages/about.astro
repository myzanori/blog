---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Myst-Blog" description="About Mohammed Yamin Salman.">
    <main class="max-w-3xl mx-auto px-4 py-24 w-full">
        <section class="text-center mb-20">
            <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-[#1d1d1f] dark:text-[#f5f5f7] mb-6">Mohammed Yamin Salman.</h1>
            <p class="text-xl md:text-2xl font-medium tracking-tight text-[#86868b]">
                Researcher & Developer based in Hyderabad.
            </p>
        </section>

        <section class="prose prose-lg prose-slate dark:prose-invert max-w-none text-[#1d1d1f] dark:text-[#f5f5f7] prose-headings:font-bold prose-headings:tracking-tight prose-a:text-[#0066cc] dark:prose-a:text-[#2997ff] prose-a:no-underline hover:prose-a:underline">
            <h2 class="text-3xl mb-6">Hello, World.</h2>
            <p class="text-xl font-medium leading-relaxed mb-10 text-[#86868b] dark:text-[#86868b]">I'm a 22-year-old bridging the gap between pharmaceutical research and software development. I enjoy building tools, websites, and exploring the intersection of technology and science.</p>
            
            <h3 class="text-2xl mb-6">Education.</h3>
            <ul class="space-y-4 text-lg font-medium text-[#86868b] dark:text-[#86868b] list-none pl-0">
                <li class="border-b border-black/5 dark:border-white/10 pb-4">
                    <strong class="text-[#1d1d1f] dark:text-[#f5f5f7] block text-xl">Master of Pharmacy in Pharmaceutical Chemistry</strong>
                    Anwar Ul Uloom College of Pharmacy &bull; 2025-2027
                </li>
                <li class="border-b border-black/5 dark:border-white/10 pb-4">
                    <strong class="text-[#1d1d1f] dark:text-[#f5f5f7] block text-xl">Bachelor of Pharmacy</strong>
                    Deccan School of Pharmacy &bull; 2021-2025
                </li>
            </ul>

            <h3 class="text-2xl mt-16 mb-6">Publications.</h3>
            <ul class="space-y-6 text-lg font-medium text-[#86868b] dark:text-[#86868b] list-none pl-0">
                <li>
                    <a href="https://journaljpri.com/index.php/JPRI/article/view/7697" target="_blank" class="text-xl block mb-1">Research Publication in JPRI</a>
                    Journal of Pharmaceutical Research International
                </li>
                <li>
                    <a href="https://www.ijdra.com/index.php/journal/article/view/769" target="_blank" class="text-xl block mb-1">A study on the US FDA Regulatory requirements for Stem Cell Based-Products</a>
                    International Journal of Drug Regulatory Affairs
                </li>
            </ul>

            <h3 class="text-2xl mt-16 mb-6">Connect.</h3>
            <p class="text-lg font-medium text-[#86868b]">You can find my code and projects on <a href="https://github.com/myst-25">GitHub</a>, follow me on <a href="https://x.com/Myst25_">X (Twitter)</a>, or reach out via <a href="mailto:mohammedyaminsalman@gmail.com">Email</a>.</p>
        </section>
    </main>
</Layout>
